# ── Database ──────────────────────────────────────────────────────
# CRITICAL: Use pooler URL (port 6543) for app. Direct (5432) only for Alembic.
DATABASE_URL=postgresql://dev:dev@localhost:5432/crmind
DATABASE_URL_DIRECT=postgresql://dev:dev@localhost:5432/crmind

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── FOR LOCAL DEVELOPMENT (running backend directly, not via Docker) ──
# DATABASE_URL=postgresql://dev:dev@localhost:5432/crmind
# REDIS_URL=redis://localhost:6379

# ── FOR DOCKER COMPOSE (running via docker compose up) ───────────────
# Copy these values into your .env when using Docker:
# DATABASE_URL=postgresql://dev:dev@postgres:5432/crmind
# REDIS_URL=redis://redis:6379
# Note: 'postgres' and 'redis' are the Docker Compose service names.

# ── LLM / Embeddings ─────────────────────────────────────────────
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_LLM_MODEL_FALLBACK=llama-3.1-8b-instant
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
SUPABASE_SERVICE_ROLE_KEY=

# Deployment notes:
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...

# ── Supabase Auth ────────────────────────────────────────────────
# From Supabase dashboard → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# From Supabase dashboard → Settings → API → JWT Settings → JWT Secret
# This is used to verify JWT tokens WITHOUT calling Supabase on every request
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Personal API key for internal service calls (worker → API, GitHub Actions)
# This is NOT a user key — it is a single service account key
INTERNAL_SERVICE_API_KEY=internal-secret-change-in-production

# ── API ────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
ENVIRONMENT=local

# ── Crawling ───────────────────────────────────────────────────────
RESPECT_ROBOTS_TXT=true
CRAWL_MIN_DELAY_SECONDS=3.0
CRAWL_MAX_ATTEMPTS=3
CRAWL_TIMEOUT_MS=15000
CRAWL_USE_BROWSER_DOMAINS=

# ── Retrieval ──────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_FINAL=8
MAX_TOP_K=50
MIN_SIMILARITY=0.3

# ── Cache ──────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=3600

# ── DB Pool ────────────────────────────────────────────────────────
# CRITICAL: max 5 for Supabase free tier (60 connection hard limit)
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text

# ── CORS ───────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_SITE_URL=http://localhost:3000
