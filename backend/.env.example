# Backend runtime env (local/dev)
DATABASE_URL=postgresql://dev:dev@localhost:5432/crmind
DATABASE_URL_DIRECT=postgresql://dev:dev@localhost:5432/crmind
REDIS_URL=redis://localhost:6379

# Providers
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Supabase/JWT auth
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# API/auth
API_KEY=dev-secret-key-change-in-production
INTERNAL_SERVICE_API_KEY=internal-secret-change-in-production
ENVIRONMENT=local

# Crawl/retrieval/cache
RESPECT_ROBOTS_TXT=true
CRAWL_MIN_DELAY_SECONDS=3.0
CRAWL_MAX_ATTEMPTS=3
CRAWL_TIMEOUT_MS=15000
TOP_K_RETRIEVAL=20
TOP_K_FINAL=8
MAX_TOP_K=50
MIN_SIMILARITY=0.3
CACHE_TTL_SECONDS=3600

# DB pool (free-tier safe)
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
