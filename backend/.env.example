DATABASE_URL=postgresql://dev:dev@localhost:5432/crmind
DATABASE_URL_DIRECT=postgresql://dev:dev@localhost:5432/crmind
REDIS_URL=redis://localhost:6379
GROQ_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-here
API_KEY=dev-secret-key-change-in-production
INTERNAL_SERVICE_API_KEY=internal-secret-change-in-production
ENVIRONMENT=local
RESPECT_ROBOTS_TXT=true
CRAWL_MIN_DELAY_SECONDS=3.0
CRAWL_MAX_ATTEMPTS=3
CRAWL_TIMEOUT_MS=15000
TOP_K_RETRIEVAL=20
TOP_K_FINAL=8
MAX_TOP_K=50
MIN_SIMILARITY=0.3
CACHE_TTL_SECONDS=3600
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
LOG_LEVEL=INFO
LOG_FORMAT=text
# CRITICAL FOR DEPLOYMENT: Set this to your frontend domain!
# Local: http://localhost:3000
# Production: https://search-gateway-tau.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000
