# Frontend runtime env - Required for deployment

# Backend API URL
# Local: http://localhost:8000
# Production: https://crmind-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://crmind-api.onrender.com

# Supabase credentials (from https://app.supabase.io → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL for OAuth/email callbacks
# Local: http://localhost:3000
# Production: https://search-gateway-tau.vercel.app
NEXT_PUBLIC_SITE_URL=https://search-gateway-tau.vercel.app
